{
  "name": "ai-relay",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first context portability across AI providers.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "check": "node scripts/check-repository.mjs",
    "test": "node --test",
    "build:browser": "node scripts/build-browser.mjs",
    "validate:browser-release": "node scripts/validate-browser-release.mjs",
    "package:browser": "npm run build:browser && npm run validate:browser-release && node scripts/package-browser-release.mjs",
    "install:macos-native-host": "node apps/macos/scripts/install-native-host.mjs",
    "build:macos-menu-bar": "bash apps/macos/scripts/build-menu-bar.sh",
    "package:macos-menu-bar": "bash apps/macos/scripts/package-menu-bar-app.sh",
    "launch:macos-menu-bar": "bash apps/macos/scripts/launch-menu-bar-app.sh",
    "install:macos-companion": "bash apps/macos/scripts/install-macos-companion.sh"
  }
}
